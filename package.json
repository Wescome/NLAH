{
  "name": "@wescome/nlah",
  "version": "0.1.0",
  "description": "Natural-Language Agent Harness runtime for artifact-gated crews.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "nlah": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "run:mvp": "tsx src/cli.ts run --harness harnesses/crew.mvp.yaml --repo examples/target_repo_stub --task examples/TASK.md",
    "run:script-demo": "tsx examples/script_worker_demo.ts",
    "run:mock-llm-demo": "tsx examples/mock_llm_demo.ts",
    "run:local-cli-demo": "tsx examples/local_cli_demo.ts",
    "run:aider-patch-demo": "tsx examples/aider_patch_demo.ts",
    "run:pi-patch-demo": "tsx examples/pi_patch_demo.ts",
    "run:loom-patch-demo": "tsx examples/loom_patch_demo.ts",
    "run:legacy-coding-swarm": "tsx src/cli.ts run --harness harnesses/coding_swarm.mvp.yaml --repo examples/target_repo_stub --task examples/TASK.md",
    "verify": "pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
